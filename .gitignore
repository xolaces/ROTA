# =============================================================
# ROTA .gitignore
# Based on Visual Studio template + ROTA-specific additions
# =============================================================

# ----- SECRETS — NEVER COMMIT -----
.env
*.pfx
*.p12
*.key
*.pem
secrets.json
appsettings.*.local.json

# ----- BUILD ARTIFACTS -----
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
out/
publish/

# ----- .NET -----
*.user
*.suo
*.userosscache
*.sln.docstates
project.lock.json
project.fragment.lock.json
artifacts/
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# ----- VISUAL STUDIO -----
.vs/
.vscode/
*.ncrunchsolution
*.ncrunchproject
_NCrunch_*
nCrunchTemp_*
*.VisualState.xml
TestResult.xml
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.tte
*.jmconfig
*.btp.cs
*.btm.cs
*.odx.cs
*.xsd.cs
*.Cache
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs

# ----- RIDER -----
.idea/
*.sln.iml

# ----- NUGET -----
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.nuget.cache

# ----- DOTNET USER SECRETS -----
# These live outside the repo in %APPDATA%\Microsoft\UserSecrets
# Listing here as a reminder — they are never IN the repo
# Location: %APPDATA%\Microsoft\UserSecrets\<guid>\secrets.json  (Windows)
#           ~/.microsoft/usersecrets/<guid>/secrets.json           (Mac/Linux)

# ----- DOCKER -----
# .env is already listed above — do not add docker-compose.override.yml
# if it contains secrets
docker-compose.override.yml

# ----- OS -----
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ----- MIGRATION SNAPSHOTS (keep these — they are source-controlled) -----
# Do NOT add **/Migrations/ here